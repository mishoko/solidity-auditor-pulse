{
  "name": "benchmark-runner",
  "version": "0.1.0",
  "description": "Benchmark solidity-auditor Claude Code skill vs bare Claude baseline",
  "type": "module",
  "main": "dist/runner/cli.js",
  "bin": {
    "bench": "dist/runner/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "bench": "tsc && node dist/runner/cli.js",
    "bench:dry": "tsc && node dist/runner/cli.js --dry-run",
    "analyze": "tsc && node dist/classifier/pipeline-cli.js",
    "analyze:cheap": "tsc && node dist/classifier/pipeline-cli.js --no-validate",
    "report": "tsc && node dist/reports/report-cli.js",
    "report:latest": "tsc && node dist/reports/report-cli.js --latest",
    "dashboard": "tsc && node dist/dashboard/render.js",
    "setup": "mkdir -p results workspaces && touch results/.nosync workspaces/.nosync && echo 'Sync protection markers created.'"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
